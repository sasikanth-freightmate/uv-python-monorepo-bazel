        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Run: greeter",
      "type": "shell",
      "command": "bazel run //apps/greeter",
      "problemMatcher": []
    },
    {
      "label": "Run: hello",
      "type": "shell",
      "command": "bazel run //apps/hello",
      "problemMatcher": []
    },
    {
      "label": "Regenerate requirements.txt",
      "type": "shell",
      "command": "bazel run //:generate_requirements_txt",
      "problemMatcher": []
    }
  ]
