# flow-backend environment — copy to .env and fill in values for local dev.
# All vars are read case-insensitively. Required vars have no default.

# ── Required ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/flow_backend
REDIS_URL=redis://localhost:6379/0

# ── Optional (defaults shown) ─────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
HEALTH_HOST=0.0.0.0
HEALTH_PORT=8080
TEMPORAL_ADDRESS=localhost:7233
